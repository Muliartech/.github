# --- Required to deploy contracts ---
# A wallet private key that holds testnet USDC on Arc Testnet (used for gas).
# NEVER commit your real private key. Use a throwaway wallet for testnet only.
PRIVATE_KEY=0xPASTE_YOUR_TESTNET_PRIVATE_KEY_HERE

# --- Optional overrides ---
ARC_RPC_URL=https://rpc.testnet.arc.network
ARCSCAN_API_KEY=empty

# --- Filled in AFTER you deploy (used by the verify script) ---
ZOMBIE_COIN_ADDRESS=
ZOMBIE_HERO_ADDRESS=
ZOMBIE_GAME_ADDRESS=

# Testnet USDC on Arc (the gas token). Used by the Hero contract for paid mints.
# Replace with the real testnet USDC address from https://docs.arc.network
USDC_ADDRESS=0x0000000000000000000000000000000000000000
